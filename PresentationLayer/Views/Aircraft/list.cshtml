@using DataModels.VM.Aircraft;
@model List<AirCraftVM>
@{
    Layout = null;
}

@{
    <div class="row">
        @foreach (AirCraftVM airCraftVM in Model)
        {
        <div class="col-6 col-md-4 col-lg-3 col-xl-3">
            <div class="card">
                <a href="@Url.Action("Edit","AirCraft",new { id = airCraftVM.Id})" class="btnedit" data-id="@airCraftVM.Id" style="cursor: pointer">
                    <img src="@airCraftVM.ImagePath" onerror="this.onerror=null;this.src='../img/thumbnail-aircraft.png';" class="card-img-top" style="height:12rem">
                    <div class="card-body" style="border-top:solid;border-color:black;">
                        <h5 class="card-title">@airCraftVM.TailNo</h5>
                    </div>
                </a>
            </div>
        </div>
        }
    </div>
}
